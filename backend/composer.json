{
    "name": "tb_realms/php-backend",
    "description": "PHP backend for Tradeborn Realms game",
    "license": "proprietary",
    "type": "project",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:5002 -t public",
        "test": "phpunit",
        "cs-check": "@php scripts/csCheck.php",
        "cs-fix": "@php scripts/csCheck.php"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
